<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>mvc</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
  </welcome-file-list>
  
  <servlet>
  	<servlet-name>ProductFrontController</servlet-name>
  	<servlet-class>com.app.product.ProductFrontController</servlet-class>
  </servlet>
  
  <servlet-mapping>
  	<servlet-name>ProductFrontController</servlet-name>
  	<url-pattern>*.product</url-pattern>
  </servlet-mapping>
  
  <servlet>
  	<servlet-name>PostFrontController</servlet-name>
  	<servlet-class>com.app.post.PostFrontController</servlet-class>
  </servlet>
  
  <servlet-mapping>
  	<servlet-name>PostFrontController</servlet-name>
  	<url-pattern>*.post</url-pattern>
  </servlet-mapping>
  
  <servlet>
  	<servlet-name>PostList</servlet-name>
  	<jsp-file>/postList.jsp</jsp-file>
  </servlet>
  
  <servlet-mapping>
  	<servlet-name>PostList</servlet-name>
  	<url-pattern>/postList</url-pattern>
  </servlet-mapping>
  
    <servlet>
  	<servlet-name>PostWrite</servlet-name>
  	<jsp-file>/postWrite.jsp</jsp-file>
  </servlet>
  
  <servlet-mapping>
  	<servlet-name>PostWrite</servlet-name>
  	<url-pattern>/postWrite</url-pattern>
  </servlet-mapping>
  
      <servlet>
  	<servlet-name>PostRead</servlet-name>
  	<jsp-file>/postRead.jsp</jsp-file>
  </servlet>
  
  <servlet-mapping>
  	<servlet-name>PostRead</servlet-name>
  	<url-pattern>/postRead</url-pattern>
  </servlet-mapping>
  
        <servlet>
  	<servlet-name>PostUpdate</servlet-name>
  	<jsp-file>/postUpdate.jsp</jsp-file>
  </servlet>
  
  <servlet-mapping>
  	<servlet-name>PostUpdate</servlet-name>
  	<url-pattern>/postUpdate</url-pattern>
  </servlet-mapping>
</web-app>